#!/usr/bin/env zsh

# Script to initialize a git worktree for parallel Claude Code work
# Usage: init-worktree <ticket-id> <short-description>

# Check we're in a git repo
git rev-parse --git-dir >/dev/null 2>&1 || { echo "Error: Not in a git repository"; exit 1; }

# Check if correct number of arguments provided
if [[ $# -ne 2 ]]; then
    echo "Error: Script requires exactly 2 arguments"
    echo "Usage: $0 <ticket-id> <short-description>"
    echo "Example: $0 MHOUSE-1234 'foo bar baz'"
    exit 1
fi

# Get arguments
TICKET_ID="$1"
SHORT_DESC="$2"

# Create branch name: lowercase, replace non-alphanumeric with hyphens, collapse/trim
BRANCH_NAME=$(echo "${TICKET_ID}-${SHORT_DESC}" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9._-]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//')

echo "Creating worktree with branch: $BRANCH_NAME"

# Get the repo name from the git toplevel directory
REPO_NAME=$(basename "$(git rev-parse --show-toplevel)")

# Static workspace under ~/code/worktrees/<repo_name>
WORKTREE_BASE="$HOME/code/worktrees/${REPO_NAME}"
WORKTREE_DIR="${WORKTREE_BASE}/${BRANCH_NAME}"

# Ensure the base directory exists
mkdir -p "$WORKTREE_BASE"

# Check if worktree already exists
if [[ -d "$WORKTREE_DIR" ]]; then
    echo "Error: Worktree directory already exists: $WORKTREE_DIR"
    exit 1
fi

# Create the git worktree
echo "Creating worktree in: $WORKTREE_DIR"
git worktree add "$WORKTREE_DIR" -b "$BRANCH_NAME" || {
    echo "Error: Failed to create git worktree"
    exit 1
}

# Copy .claude/settings.local.json if it exists in current project
if [[ -f ".claude/settings.local.json" ]]; then
    echo "Copying .claude/settings.local.json to new worktree..."

    mkdir -p "${WORKTREE_DIR}/.claude"

    cp ".claude/settings.local.json" "${WORKTREE_DIR}/.claude/settings.local.json" || {
        echo "Warning: Failed to copy .claude/settings.local.json"
    }
else
    echo "Note: .claude/settings.local.json not found in current directory"
fi

echo ""
echo "✓ Worktree successfully created!"
echo "  Repo: $REPO_NAME"
echo "  Branch: $BRANCH_NAME"
echo "  Location: $WORKTREE_DIR"
echo ""
echo "To start working:"
echo "  cd $WORKTREE_DIR"
echo ""
echo "To remove this worktree when done:"
echo "  git worktree remove $WORKTREE_DIR"
